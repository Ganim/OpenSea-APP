{
  "ci": {
    "collect": {
      "startServerCommand": "npx next start -p 3000",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://localhost:3000/login",
        "http://localhost:3000/register"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-gpu --headless",
        "onlyCategories": ["accessibility", "best-practices", "performance", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.85, "aggregationMethod": "median-run" }],
        "categories:best-practices": ["warn", { "minScore": 0.80, "aggregationMethod": "median-run" }],
        "categories:performance": ["warn", { "minScore": 0.60, "aggregationMethod": "median-run" }],
        "categories:seo": ["warn", { "minScore": 0.80, "aggregationMethod": "median-run" }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
